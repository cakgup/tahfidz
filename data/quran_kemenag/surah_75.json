      "surah_id": 75,
      "ayah": 3,
      "page": 577,
      "juz": 29,
      "arabic": "اَيَحْسَبُ الْاِنْسَانُ اَلَّنْ نَّجْمَعَ عِظَامَهٗ ۗ",
      "kitabah": "اَيَحْسَبُ الْاِنْسَانُ اَلَّنْ نَّجْمَعَ عِظَامَهٗ ۗ",
